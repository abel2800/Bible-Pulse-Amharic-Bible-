rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function moderator() {
      return signedIn() && request.auth.token.moderator == true;
    }

    match /users/{userId}/study/{recordId} {
      allow read, delete: if owns(userId);
      allow create: if owns(userId)
        && request.resource.data.ownerId == userId;
      allow update: if owns(userId)
        && request.resource.data.ownerId == userId
        && request.resource.data.ownerId == resource.data.ownerId;
    }

    match /users/{userId}/blocks/{blockedUserId} {
      allow read, create, delete: if owns(userId);
      allow update: if false;
    }

    match /users/{userId}/rateLimits/{limitId} {
      allow read: if owns(userId);
      allow create, update: if owns(userId)
        && request.resource.data.lastCreatedAt == request.time;
      allow delete: if false;
    }

    match /communityPosts/{postId} {
      allow read: if resource.data.status == 'visible' || moderator();
      allow create: if signedIn()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.status == 'visible'
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 2000
        && request.resource.data.reportCount == 0;
      allow update: if moderator()
        || (signedIn()
          && resource.data.authorId == request.auth.uid
          && request.resource.data.authorId == resource.data.authorId
          && request.resource.data.status == 'removed'
          && request.resource.data.body == '');
      allow delete: if moderator();
    }

    match /communityReports/{reportId} {
      allow create: if signedIn()
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.status == 'open';
      allow read, update, delete: if moderator();
    }

    match /studyGroups/{groupId} {
      allow read: if signedIn() &&
        request.auth.uid in resource.data.memberIds;
      allow create: if signedIn() &&
        request.resource.data.ownerId == request.auth.uid &&
        request.auth.uid in request.resource.data.memberIds;
      allow update: if signedIn() && (
        resource.data.ownerId == request.auth.uid ||
        (
          request.auth.uid in resource.data.memberIds &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['progressByUser']) &&
          request.resource.data.progressByUser
            .diff(resource.data.progressByUser).affectedKeys()
            .hasOnly([request.auth.uid])
        )
      );
      allow delete: if signedIn() &&
        resource.data.ownerId == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
